<!DOCTYPE html>
<html lang="es">

<%- include('partials/head', { pageTitle: 'Listado' }) %>

  <body>

    <%- include('partials/header', { navLinks: [ { href: '/terceros' , label: 'Terceros' }, {
      href: '/resoluciones/nueva' , label: 'Nueva Resolución' }, { href: '/resoluciones' , label: 'Listado' , active:
      true } ] }) %>

      <main class="main">

        <% if (message) { %>
          <div class="alert alert-<%= message.type %>">
            <span>
              <%= message.type==='success' ? '✓' : '✕' %>
            </span>
            <%= message.text %>
          </div>
          <% } %>

            <div class="page-header">
              <div class="page-title">Registro de Resoluciones</div>
              <div class="page-subtitle">Gestión y control de resoluciones de facturación</div>
            </div>


            <div class="stats" style="margin-top:8px">
              <div class="stat-card" style="border-left:3px solid #e74c3c">
                <div class="stat-num" style="color:#e74c3c">
                  <%= vencidasTotal %>
                </div>
                <div class="stat-label">Vencidas (Total)</div>
              </div>
              <div class="stat-card" style="border-left:3px solid #c0392b">
                <div class="stat-num" style="color:#c0392b">
                  <%= vencidasHoy %>
                </div>
                <div class="stat-label">Vencen Hoy</div>
              </div>
              <div class="stat-card" style="border-left:3px solid #e67e22">
                <div class="stat-num" style="color:#e67e22">
                  <%= porVencer1 %>
                </div>
                <div class="stat-label">Por vencer en 1 día</div>
              </div>
              <div class="stat-card" style="border-left:3px solid #f39c12">
                <div class="stat-num" style="color:#f39c12">
                  <%= porVencer5 %>
                </div>
                <div class="stat-label">Por vencer en 5 días</div>
              </div>
              <div class="stat-card" style="border-left:3px solid #f1c40f">
                <div class="stat-num" style="color:#d4ac0d">
                  <%= porVencer15 %>
                </div>
                <div class="stat-label">Por vencer en 15 días</div>
              </div>
              <div class="stat-card" style="border-left:3px solid #3498db">
                <div class="stat-num" style="color:#3498db">
                  <%= enVencimiento %>
                </div>
                <div class="stat-label">En Vencimiento</div>
              </div>
            </div>

            <form method="GET" action="/resoluciones" class="filters">
              <div class="filter-group">
                <label>Buscar</label>
                <input type="text" name="search" style="min-width:300px" value="<%= search %>"
                  placeholder="NIT, nombre, resolución, prefijo...">
              </div>
              <div class="filter-group">
                <label>Modalidad</label>
                <select name="modalidad">
                  <option value="">Todas</option>
                  <option value="D.E. / P.O.S." <%=modalidad==='D.E. / P.O.S.' ? 'selected' : '' %>>D.E. / P.O.S.
                  </option>
                  <option value="Documento soporte" <%=modalidad==='Documento soporte' ? 'selected' : '' %>>Documento
                    soporte</option>
                  <option value="Facturación computador" <%=modalidad==='Facturación computador' ? 'selected' : '' %>
                    >Facturación computador</option>
                  <option value="Facturación de papel" <%=modalidad==='Facturación de papel' ? 'selected' : '' %>
                    >Facturación de papel</option>
                  <option value="Factura de talonario o de papel" <%=modalidad==='Factura de talonario o de papel'
                    ? 'selected' : '' %>>Factura de talonario</option>
                  <option value="Factura electrónica de venta" <%=modalidad==='Factura electrónica de venta'
                    ? 'selected' : '' %>>Factura electrónica</option>
                </select>
              </div>
              <div class="filter-group">
                <label>Solicitud</label>
                <select name="solicitud">
                  <option value="">Todas</option>
                  <option value="Autorización" <%=solicitud==='Autorización' ? 'selected' : '' %>>Autorización</option>
                  <option value="Habilitación" <%=solicitud==='Habilitación' ? 'selected' : '' %>>Habilitación</option>
                  <option value="Inhabilitación" <%=solicitud==='Inhabilitación' ? 'selected' : '' %>>Inhabilitación
                  </option>
                </select>
              </div>
              <div class="filter-group">
                <label>Vencimiento</label>
                <select name="vencimiento">
                  <option value="">Todas</option>
                  <option value="vencidas" <%=vencimiento==='vencidas' ? 'selected' : '' %>>Vencidas (Total)</option>
                  <option value="hoy" <%=vencimiento==='hoy' ? 'selected' : '' %>>Vencen hoy</option>
                  <option value="1dia" <%=vencimiento==='1dia' ? 'selected' : '' %>>Por vencer en 1 día</option>
                  <option value="15dias" <%=vencimiento==='15dias' ? 'selected' : '' %>>Por vencer en 15 días</option>
                </select>
              </div>
              <button type="submit" class="btn btn-primary">Filtrar</button>
              <% if (search || modalidad || solicitud || vencimiento) { %>
                <a href="/resoluciones" class="btn btn-ghost">Limpiar</a>
                <% } %>
            </form>

            <div class="table-card">
              <div class="table-header">
                <span class="table-title">Listado de Resoluciones</span>
                <div style="display:flex;gap:8px;align-items:center">
                  <span class="table-count" style="margin-right:8px">
                    <%= totalFiltered %> registro<%= totalFiltered !==1 ? 's' : '' %>
                  </span>
                  <button type="button" class="btn btn-danger" id="btnConfirmBulkDelete"
                    style="padding:5px 12px;font-size:12px;height:32px;border-radius:18px;display:none">
                    🗑️ Eliminar seleccionados (<span id="selectedCount">0</span>)
                  </button>
                  <button type="button" class="btn btn-outline btn-sm btn-del" id="btnToggleBulkDelete"
                    title="Modo eliminación masiva">
                    🗑️
                  </button>
                </div>
              </div>
              <div class="table-wrap">
                <% if (resoluciones.length===0) { %>
                  <div class="empty-state">
                    <div class="icon">📄</div>
                    <p>No se encontraron resoluciones</p>
                    <span>Registre una nueva resolución o ajuste los filtros de búsqueda</span>
                  </div>
                  <% } else { %>
                    <table>
                      <thead>
                        <tr>
                          <th>#</th>
                          <th class="th-sortable" data-col="nit">
                            <span class="th-sort-label">NIT</span>
                            <button type="button" class="th-sort-btn" title="Ordenar por NIT"
                              onclick="sortTable('nit', this)">
                              <span class="sort-arrow">↕</span>
                            </button>
                          </th>
                          <th class="th-sortable" data-col="nombre">
                            <span class="th-sort-label">Nombre</span>
                            <button type="button" class="th-sort-btn" title="Ordenar por Nombre"
                              onclick="sortTable('nombre', this)">
                              <span class="sort-arrow">↕</span>
                            </button>
                          </th>
                          <th>Resolución</th>
                          <th class="th-sortable" data-col="fecha">
                            <span class="th-sort-label">Fecha</span>
                            <button type="button" class="th-sort-btn" title="Ordenar por Fecha"
                              onclick="sortTable('fecha', this)">
                              <span class="sort-arrow">↕</span>
                            </button>
                          </th>
                          <th>Modalidad</th>
                          <th>Solicitud</th>
                          <th>Establecimiento</th>
                          <th>Prefijo</th>
                          <th>Desde</th>
                          <th>Hasta</th>
                          <th>Vigencia</th>
                          <th>Vencimiento</th>
                          <th style="width:100px;text-align:center">
                            <span id="labelAcciones">Acciones</span>
                            <div id="checkAllWrapper" style="display:none">
                              <input type="checkbox" id="chkSelectAll" style="width:16px;height:16px;cursor:pointer">
                            </div>
                          </th>
                        </tr>
                      </thead>
                      <tbody>
                        <% resoluciones.forEach((r, i)=> {
                          // Helper: format number with dots as thousands separator
                          function _fmt(n) { return n == null ? '—' : String(n).replace(/\B(?=(\d{3})+(?!\d))/g, '.'); }
                          // Calculate days until expiry for row coloring (skip if checked)
                          let _rowBg = '';
                          const _vig = parseInt(r.vigencia);
                          if (!r.checked && !isNaN(_vig) && r.fecha_resolucion) {
                          const _hoy = new Date(); _hoy.setHours(0,0,0,0);
                          const _fv = new Date(r.fecha_resolucion + 'T00:00:00');
                          _fv.setMonth(_fv.getMonth() + _vig);
                          const _diff = Math.ceil((_fv - _hoy) / (1000 * 60 * 60 * 24));
                          if (_diff < 0) _rowBg='background:rgba(231,76,60,0.10)' ; else if (_diff===0)
                            _rowBg='background:rgba(192,57,43,0.15)' ; else if (_diff===1)
                            _rowBg='background:rgba(230,126,34,0.12)' ; else if (_diff <=5)
                            _rowBg='background:rgba(241,196,15,0.12)' ; } %>
                            <tr style="<%= _rowBg %>">
                              <td class="td-num" style="color:var(--muted)">
                                <%= startIndex + i + 1 %>
                              </td>
                              <td class="td-num">
                                <% const _nitClean=r.nit ? r.nit.split('-')[0] : '' ; %>
                                  <span class="copy-nombre" data-tooltip="Copiar" onclick="copyNombre(this)">
                                    <%= Number(_nitClean) ? _fmt(_nitClean) : _nitClean %>
                                  </span>
                              </td>
                              <td>
                                <span class="copy-nombre" data-tooltip="Copiar" onclick="copyNombre(this)">
                                  <%= r.nombre_tercero %>
                                </span>
                              </td>
                              <td class="td-num">
                                <span class="copy-nombre" data-tooltip="Copiar" onclick="copyNombre(this)">
                                  <%= r.numero_resolucion %>
                                </span>
                              </td>
                              <td style="white-space:nowrap">
                                <% if (r.fecha_resolucion) { const _fp=r.fecha_resolucion.split('-'); %>
                                  <%= _fp[2] %>/<%= _fp[1] %>/<%= _fp[0] %>
                                        <% } else { %>—<% } %>
                              </td>
                              <td>
                                <span class="badge badge-modal">
                                  <%= r.modalidad %>
                                </span>
                              </td>
                              <td>
                                <span class="badge <%=
                r.solicitud === 'Autorización' ? 'badge-auth' :
                r.solicitud === 'Habilitación' ? 'badge-hab' : 'badge-inhab'
              %>">
                                  <%= r.solicitud %>
                                </span>
                              </td>
                              <td style="font-size:12px">
                                <span class="copy-nombre" data-tooltip="Copiar" onclick="copyNombre(this)">
                                  <%= r.sucursal || '—' %>
                                </span>
                              </td>
                              <td class="td-num">
                                <span class="copy-nombre" data-tooltip="Copiar" onclick="copyNombre(this)">
                                  <%= r.prefijo || '—' %>
                                </span>
                              </td>
                              <td
                                style="white-space:nowrap;font-family:'IBM Plex Mono',monospace;font-size:12px; text-align: right;">
                                <%= _fmt(r.desde) %>
                              </td>
                              <td
                                style="white-space:nowrap;font-family:'IBM Plex Mono',monospace;font-size:12px; text-align: right;">
                                <%= _fmt(r.hasta) %>
                              </td>
                              <td style="font-size:13px;white-space:nowrap">
                                <%= r.vigencia %> mes<%= r.vigencia==1 ? '' : 'es' %>
                              </td>
                              <td class="td-vencimiento" style="font-size:13px;white-space:nowrap"
                                data-id="<%= r.id %>">
                                <% if (!r.checked) { %>
                                  <% const mv=parseInt(r.vigencia); if (!isNaN(mv) && r.fecha_resolucion) { const bv=new
                                    Date(r.fecha_resolucion + 'T00:00:00' ); bv.setMonth(bv.getMonth() + mv); const
                                    dv=String(bv.getDate()).padStart(2,'0'); const
                                    mv2=String(bv.getMonth()+1).padStart(2,'0'); const av=bv.getFullYear(); %>
                                    <%= dv %>/<%= mv2 %>/<%= av %>
                                          <% } else { %>—<% } %>
                                              <% } else { %>—<% } %>
                              </td>
                              <td>
                                <div class="actions-wrapper-bulk" style="display:none">
                                  <input type="checkbox" class="bulk-select-chk" data-id="<%= r.id %>"
                                    style="width:18px;height:18px;cursor:pointer">
                                </div>
                                <div class="actions-wrapper-single">
                                  <button type="button" class="btn btn-sm btn-toggle-actions" title="Acciones"
                                    onclick="toggleActions(this)">
                                    <span class="toggle-icon">+</span>
                                  </button>
                                  <div class="actions-panel">
                                    <% if (r.has_pdf) { %>
                                      <a href="<%= ftpBaseUrl %>/<%= encodeURIComponent(r.fecha_resolucion + '-' + r.numero_resolucion + '.pdf') %>"
                                        target="_blank" class="btn btn-sm btn-outline" title="Ver PDF"
                                        style="color:#E67E22;border-color:#E67E22">📁</a>
                                      <% } else { %>
                                        <input type="file" id="pdfUpload_<%= r.id %>" accept=".pdf" style="display:none"
                                          onchange="subirPdfResolucion(<%= r.id %>, this)">
                                        <button type="button" class="btn btn-sm btn-outline" title="Subir PDF"
                                          style="color:#3498db;border-color:#3498db"
                                          onclick="document.getElementById('pdfUpload_<%= r.id %>').click()">📤</button>
                                        <% } %>
                                          <a href="/resoluciones/<%= r.id %>" class="btn btn-sm btn-outline"
                                            title="Ver detalle">👁</a>
                                          <button type="button"
                                            class="btn btn-sm btn-check-toggle <%= r.checked ? 'checked' : '' %>"
                                            title="Marcar" data-id="<%= r.id %>" onclick="toggleCheck(this)">
                                            <span class="check-icon">
                                              <%= r.checked ? '☑' : '☐' %>
                                            </span>
                                          </button>
                                          <a href="/resoluciones/<%= r.id %>/editar" class="btn btn-sm btn-gold"
                                            title="Editar">✏️</a>
                                          <form method="POST" action="/resoluciones/<%= r.id %>?_method=DELETE"
                                            style="display:inline"
                                            onsubmit="return confirm('¿Eliminar esta resolución?')">
                                            <button type="submit" class="btn btn-sm btn-danger"
                                              title="Eliminar">🗑</button>
                                          </form>
                                  </div>
                                </div>
                              </td>
                            </tr>
                            <% }); %>
                      </tbody>
                    </table>
                    <% } %>
              </div>
              <div id="bulkDeleteToast" class="bulk-toast" style="display:none">
                <div class="bulk-toast-content">
                  <span class="bulk-toast-text">Modo Selección Activo</span>
                  <button type="button" class="btn-bulk-cancel" onclick="disableBulkDelete()">✕</button>
                </div>
              </div>
              <% if (totalPages> 1) { %>
                <div class="pagination">
                  <% var qs='&search=' + encodeURIComponent(search) + '&modalidad=' + encodeURIComponent(modalidad)
                    + '&solicitud=' + encodeURIComponent(solicitud) + '&vencimiento=' + encodeURIComponent(vencimiento);
                    %>
                    <% if (currentPage> 1) { %>
                      <a href="/resoluciones?page=<%= currentPage - 1 %><%= qs %>" class="pagination-btn">&laquo;
                        Anterior</a>
                      <% } else { %>
                        <span class="pagination-btn disabled">&laquo; Anterior</span>
                        <% } %>
                          <% for (var p=1; p <=totalPages; p++) { %>
                            <% if (p===currentPage) { %>
                              <span class="pagination-btn active">
                                <%= p %>
                              </span>
                              <% } else { %>
                                <a href="/resoluciones?page=<%= p %><%= qs %>" class="pagination-btn">
                                  <%= p %>
                                </a>
                                <% } %>
                                  <% } %>
                                    <% if (currentPage < totalPages) { %>
                                      <a href="/resoluciones?page=<%= currentPage + 1 %><%= qs %>"
                                        class="pagination-btn">Siguiente &raquo;</a>
                                      <% } else { %>
                                        <span class="pagination-btn disabled">Siguiente &raquo;</span>
                                        <% } %>
                </div>
                <% } %>
            </div>

      </main>

      <%- include('partials/footer') %>
        <%- include('partials/clock') %>

          <script>
            function subirPdfResolucion(id, input) {
              if (!input.files || !input.files[0]) return;
              const file = input.files[0];
              if (file.type !== 'application/pdf') { alert('Solo se permiten archivos PDF.'); return; }
              const formData = new FormData();
              formData.append('pdf', file);
              fetch('/resoluciones/subir-pdf/' + id, { method: 'POST', body: formData })
                .then(r => r.json())
                .then(data => {
                  if (data.ok) { location.reload(); }
                  else { alert(data.error || 'Error al subir el PDF.'); }
                })
                .catch(() => alert('Error al subir el PDF.'));
            }

            function toggleCheck(btn) {
              const id = btn.dataset.id;
              fetch('/resoluciones/' + id + '/toggle-check', { method: 'PATCH' })
                .then(r => r.json())
                .then(data => {
                  if (data.ok) {
                    // Reload to recalculate stats, vencimiento and row colors
                    location.reload();
                  }
                })
                .catch(() => { });
            }

            function copyNombre(el) {
              const text = el.textContent.trim();
              navigator.clipboard.writeText(text).then(function () {
                el.setAttribute('data-tooltip', '¡Copiado!');
                setTimeout(function () { el.setAttribute('data-tooltip', 'Copiar'); }, 1500);
              });
            }

            function toggleActions(btn) {
              const wrapper = btn.closest('.actions-wrapper-single');
              const wasOpen = wrapper.classList.contains('open');
              // Close all other open panels
              document.querySelectorAll('.actions-wrapper-single.open').forEach(w => w.classList.remove('open'));
              // Toggle current
              if (!wasOpen) wrapper.classList.add('open');
            }

            // Close actions panel on click outside
            document.addEventListener('click', function (e) {
              if (!e.target.closest('.actions-wrapper-single')) {
                document.querySelectorAll('.actions-wrapper-single.open').forEach(w => w.classList.remove('open'));
              }
            });

            // Close actions panel on Escape key
            document.addEventListener('keydown', function (e) {
              if (e.key === 'Escape') {
                document.querySelectorAll('.actions-wrapper-single.open').forEach(w => w.classList.remove('open'));
              }
            });
            // ── Sort table ──
            let currentSortCol = null;
            let currentSortDir = 'asc';

            function sortTable(col, btn) {
              // Toggle direction
              if (currentSortCol === col) {
                currentSortDir = currentSortDir === 'asc' ? 'desc' : 'asc';
              } else {
                currentSortCol = col;
                currentSortDir = 'asc';
              }

              // Reset all sort buttons
              document.querySelectorAll('.th-sort-btn').forEach(b => {
                b.classList.remove('sort-active');
                b.querySelector('.sort-arrow').textContent = '↕';
              });

              // Mark active
              btn.classList.add('sort-active');
              btn.querySelector('.sort-arrow').textContent = currentSortDir === 'asc' ? '↑' : '↓';

              const tbody = document.querySelector('table tbody');
              if (!tbody) return;
              const rows = Array.from(tbody.querySelectorAll('tr'));

              // Column indices: nit=1, nombre=2, fecha=4 (0-indexed)
              const colIndex = { nit: 1, nombre: 2, fecha: 4 };
              const idx = colIndex[col];

              rows.sort((a, b) => {
                let va = a.cells[idx] ? a.cells[idx].textContent.trim() : '';
                let vb = b.cells[idx] ? b.cells[idx].textContent.trim() : '';

                if (col === 'nit') {
                  // Numeric sort
                  va = parseInt(va.replace(/\D/g, '')) || 0;
                  vb = parseInt(vb.replace(/\D/g, '')) || 0;
                  return currentSortDir === 'asc' ? va - vb : vb - va;
                }

                if (col === 'fecha') {
                  // Date format dd/mm/yyyy → comparable
                  const parseDate = s => {
                    const p = s.split('/');
                    return p.length === 3 ? new Date(p[2], p[1] - 1, p[0]) : new Date(0);
                  };
                  const da = parseDate(va);
                  const db = parseDate(vb);
                  return currentSortDir === 'asc' ? da - db : db - da;
                }

                // Alphabetic sort (nombre)
                return currentSortDir === 'asc'
                  ? va.localeCompare(vb, 'es', { sensitivity: 'base' })
                  : vb.localeCompare(va, 'es', { sensitivity: 'base' });
              });

              // Re-number rows and reappend
              rows.forEach((row, i) => {
                row.cells[0].textContent = i + 1;
                tbody.appendChild(row);
              });
            }

            // ── Bulk Delete Logic ──
            let isBulkDeleteActive = false;
            const btnToggleBulk = document.getElementById('btnToggleBulkDelete');
            const btnConfirmBulk = document.getElementById('btnConfirmBulkDelete');
            const selectAllChk = document.getElementById('chkSelectAll');
            const checkAllWrapper = document.getElementById('checkAllWrapper');
            const labelAcciones = document.getElementById('labelAcciones');
            const bulkToast = document.getElementById('bulkDeleteToast');
            const bulkCheckboxes = document.querySelectorAll('.bulk-select-chk');
            const selectedCountSpan = document.getElementById('selectedCount');

            function updateSelectedCount() {
              const count = document.querySelectorAll('.bulk-select-chk:checked').length;
              selectedCountSpan.textContent = count;
            }

            function enableBulkDelete() {
              isBulkDeleteActive = true;
              btnToggleBulk.classList.add('active');
              labelAcciones.style.display = 'none';
              checkAllWrapper.style.display = 'block';
              bulkToast.style.display = 'block';
              btnConfirmBulk.style.display = 'inline-flex';

              document.querySelectorAll('.actions-wrapper-single').forEach(el => el.style.display = 'none');
              document.querySelectorAll('.actions-wrapper-bulk').forEach(el => el.style.display = 'block');
            }

            function disableBulkDelete() {
              isBulkDeleteActive = false;
              btnToggleBulk.classList.remove('active');
              labelAcciones.style.display = 'block';
              checkAllWrapper.style.display = 'none';
              bulkToast.style.display = 'none';
              btnConfirmBulk.style.display = 'none';

              // Reset checkboxes
              if (selectAllChk) selectAllChk.checked = false;
              document.querySelectorAll('.bulk-select-chk').forEach(chk => chk.checked = false);

              document.querySelectorAll('.actions-wrapper-single').forEach(el => el.style.display = 'block');
              document.querySelectorAll('.actions-wrapper-bulk').forEach(el => el.style.display = 'none');
            }

            if (btnToggleBulk) {
              btnToggleBulk.addEventListener('click', () => {
                if (isBulkDeleteActive) disableBulkDelete();
                else enableBulkDelete();
              });
            }

            if (selectAllChk) {
              selectAllChk.addEventListener('change', () => {
                document.querySelectorAll('.bulk-select-chk').forEach(chk => chk.checked = selectAllChk.checked);
                updateSelectedCount();
              });
            }

            document.addEventListener('change', (e) => {
              if (e.target.classList.contains('bulk-select-chk')) {
                updateSelectedCount();
              }
            });

            if (btnConfirmBulk) {
              btnConfirmBulk.addEventListener('click', async () => {
                const selectedIds = Array.from(document.querySelectorAll('.bulk-select-chk:checked'))
                  .map(chk => chk.dataset.id);

                if (selectedIds.length === 0) return;

                if (confirm(`¿Está seguro de que desea eliminar ${selectedIds.length} resoluciones y sus archivos PDF correspondientes?\nEsta acción es irreversible.`)) {
                  btnConfirmBulk.disabled = true;
                  btnConfirmBulk.textContent = '⏳ Eliminando...';

                  try {
                    const resp = await fetch('/resoluciones/bulk-delete', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ ids: selectedIds })
                    });
                    const data = await resp.json();
                    if (data.ok) {
                      location.reload();
                    } else {
                      alert('Error: ' + data.error);
                      btnConfirmBulk.disabled = false;
                      btnConfirmBulk.innerHTML = `🗑️ Eliminar seleccionados (<span id="selectedCount">${selectedIds.length}</span>)`;
                    }
                  } catch (err) {
                    alert('Error de conexión');
                    btnConfirmBulk.disabled = false;
                    btnConfirmBulk.innerHTML = `🗑️ Eliminar seleccionados (<span id="selectedCount">${selectedIds.length}</span>)`;
                  }
                }
              });
            }
          </script>

  </body>

