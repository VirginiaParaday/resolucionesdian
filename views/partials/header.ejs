<header class="header">
    <div class="header-inner">
        <div class="header-top">
            <a href="/resoluciones" class="header-logo">
                <img src="/images/imperia_group.png" alt="Logo" class="logo-icon">
            </a>
            <div class="header-right">
                <div class="header-info-bar">
                    <span id="headerTime"></span>
                    <span id="headerDate"></span>
                    <span>Colombia</span>
                    <span style="border-right:none">Español</span>
                    <a href="/logout" style="margin-left:8px;padding:3px 10px;font-size:12px;color:#444;background:#F4F6F9;border:1px solid #DDE2EC;border-radius:20px;text-decoration:none;font-weight:600;white-space:nowrap;transition:all 0.15s" onmouseover="this.style.background='#E8F0FE';this.style.color='#3167ca';this.style.borderColor='#3167ca'" onmouseout="this.style.background='#F4F6F9';this.style.color='#444';this.style.borderColor='#DDE2EC'">Cerrar sesión</a>
                </div>
                <nav class="header-nav">
                    <% if (typeof navLinks !== 'undefined' && navLinks) { %>
                        <% navLinks.forEach(link => { %>
                            <a href="<%= link.href %>" class="btn-header<%= link.active ? ' active' : '' %>">
                                <%= link.label %>
                            </a>
                        <% }); %>
                    <% } %>
                </nav>
            </div>
        </div>
    </div>
</header>