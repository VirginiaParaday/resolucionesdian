<!DOCTYPE html>
<html lang="es">

<%- include('partials/head', { pageTitle: 'Terceros' }) %>

<body>

    <%- include('partials/header', { navLinks: [
        { href: '/terceros', label: 'Terceros', active: true },
        { href: '/resoluciones/nueva', label: 'Nueva Resolución' },
        { href: '/resoluciones', label: 'Listado' }
    ] }) %>

        <main class="main">

            <% if (message) { %>
                <div class="alert alert-<%= message.type %>">
                    <span>
                        <%= message.type==='success' ? '✓' : '✕' %>
                    </span>
                    <%= message.text %>
                </div>
                <% } %>

                    <div class="page-header">
                        <div class="page-title">Gestión de Terceros</div>
                        <div class="page-subtitle">Registro y administración de terceros (personas naturales y
                            jurídicas)
                        </div>
                    </div>

                    <form method="GET" action="/terceros" class="filters">
                        <div class="filter-group">
                            <label>Buscar</label>
                            <input type="text" name="search" value="<%= search %>"
                                placeholder="NIT, nombre, razón social..." style="min-width:300px">
                        </div>
                        <button type="submit" class="btn btn-primary">Filtrar</button>
                        <% if (search) { %>
                            <a href="/terceros" class="btn btn-ghost">Limpiar</a>
                        <% } %>
                        <div style="border-left: 1px solid rgba(29,28,28,0.2); height: 36px; margin: 0 12px;"></div>
                        <div style="display:flex; align-items:center; gap:6px; white-space:nowrap;">
                            <span style="font-size:24px; font-weight:700; color:var(--dian-blue);"><%= total %></span>
                            <span style="font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:0.5px;">Total Terceros</span>
                        </div>
                        <a href="/terceros/nuevo" class="btn btn-goldes" style="margin-left:auto">＋ Nuevo
                            Tercero</a>
                    </form>

                    <div class="table-card">
                        <div class="table-header">
                            <span class="table-title">Listado de Terceros</span>
                            <span class="table-count">
                                <%= terceros.length %> registro<%= terceros.length !==1 ? 's' : '' %>
                            </span>
                        </div>
                        <div class="table-wrap">
                            <% if (terceros.length===0) { %>
                                <div class="empty-state">
                                    <div class="icon">👥</div>
                                    <p>No se encontraron terceros</p>
                                    <span>Registre un nuevo tercero o ajuste los filtros de búsqueda</span>
                                </div>
                                <% } else { %>
                                    <table>
                                        <thead>
                                            <tr>
                                                <th>#</th>
                                                <th>NIT</th>
                                                <th>DV</th>
                                                <th>Tipo</th>
                                                <th>Nombre / Razón Social</th>
                                                <th>Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% terceros.forEach((t, i)=> { %>
                                                <tr>
                                                    <td class="td-num" style="color:var(--muted)">
                                                        <%= i + 1 %>
                                                    </td>
                                                    <td class="td-num">
                                                        <%= Number(t.nit).toLocaleString('es-CO') %>
                                                    </td>
                                                    <td class="td-num">
                                                        <%= t.dv || '—' %>
                                                    </td>
                                                    <td>
                                                        <span
                                                            class="badge <%= t.tipo_persona === 'Natural' ? 'badge-hab' : 'badge-auth' %>">
                                                            <%= t.tipo_persona %>
                                                        </span>
                                                    </td>
                                                    <td class="td-main">
                                                        <%= t.nombre_display %>
                                                    </td>
                                                    <td>
                                                        <div class="actions">
                                                            <a href="/terceros/<%= t.id %>/editar"
                                                                class="btn btn-sm-te bted" title="Editar">Editar</a>
                                                            <form method="POST"
                                                                action="/terceros/<%= t.id %>?_method=DELETE"
                                                                style="display:inline"
                                                                onsubmit="return confirm('¿Eliminar este tercero?')">
                                                                <button type="submit" class="btn btn-sm-te btde"
                                                                    title="Eliminar">Eliminar</button>
                                                            </form>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                        </tbody>
                                    </table>
                                    <% } %>
                        </div>
                    </div>

        </main>

        <%- include('partials/footer') %>

        <%- include('partials/clock') %>


</body>

</html>